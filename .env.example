# Collectly 双部署模式配置指南

# ================================
# 方案A: 本地部署 + 内网穿透
# ================================
DEPLOY_MODE=local

# ================================
# 方案B: 云服务器公网部署
# ================================
# DEPLOY_MODE=cloud

# ================================
# 后端配置
# ================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ================================
# 前端配置
# ================================
# 方案A: 填写内网穿透生成的公网接口地址
# 方案B: 填写云服务器公网IP/域名接口地址
API_BASE_URL=http://localhost:8000/api

# ================================
# API密钥配置
# ================================
TIKHUB_API_KEY=your_tikhub_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key

# ================================
# 访问控制（可选）
# ================================
ACCESS_PASSWORD=
ACCESS_TOKEN=
WHITE_LIST_IPS=

# ================================
# 部署模式详情
# ================================
# 方案A - 本地部署:
#   - 运行位置: 本地Windows/Mac电脑
#   - 外网打通: Cloudflare Tunnel/ngrok/frp
#   - 优势: 零服务器成本，数据完全本地私有化
#
# 方案B - 云服务器部署:
#   - 运行位置: 带独立公网IP的云轻量服务器
#   - 外网打通: 固定公网IP/自定义域名+HTTPS
#   - 优势: 24h永久在线，不依赖个人电脑
