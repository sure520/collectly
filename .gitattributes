# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must always use LF line endings
*.sh text eol=lf

# Batch files must always use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# PowerShell scripts
*.ps1 text eol=crlf

# Python source files
*.py text diff=python

# JavaScript / TypeScript / JSX / TSX
*.js text
*.jsx text
*.ts text
*.tsx text
*.json text
*.mjs text
*.cjs text

# Web
*.html text diff=html
*.css text
*.scss text
*.less text
*.vue text

# Markdown / Documentation
*.md text diff=markdown
*.yaml text
*.yml text
*.toml text
*.cfg text
*.ini text
*.conf text

# Docker
Dockerfile text
Dockerfile.* text
*.dockerfile text

# Git
.gitignore text
.gitattributes text
.gitmodules text

# Makefile
